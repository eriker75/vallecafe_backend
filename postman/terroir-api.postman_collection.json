    { "key": "token", "value": "PEGAR_JWT_AQUI", "type": "string" },
    { "key": "adminToken", "value": "PEGAR_JWT_ADMIN_AQUI", "type": "string" },
    { "key": "userId", "value": "cld_user_id", "type": "string" },
