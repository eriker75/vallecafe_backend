# ─────────────────────────────────────────────────────────────────────────────
# Valle Café — Backend · variables de entorno
# Copia este archivo a `.env` y completa los valores (mínimo POSTGRES_PASSWORD y JWT_SECRET).
# En Docker dev, docker-compose.dev.yml arma DATABASE_URL a partir de POSTGRES_*.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (PostgreSQL) ──
POSTGRES_USER=vallecafe_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vallecafe_db
POSTGRES_EXT_PORT=5432
TZ=America/Caracas
# Solo si corres SIN Docker (sin compose); con Docker la arma compose:
# DATABASE_URL=postgresql://vallecafe_user:changeme@localhost:5432/vallecafe_db?schema=public

# ── Backend / API ──
BACKEND_PORT=3000
CORS_ORIGIN=http://localhost:7050
JWT_SECRET=changeme-dev-secret-please-rotate
RUN_MIGRATIONS=true

# ── Email (dev → Mailpit; UI en http://localhost:8025) ──
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=mailpit
SMTP_PASS=mailpit
SMTP_FROM=Valle Café <noreply@vallecafe24.com>

# ── pgAdmin (dev; UI en http://localhost:5050) ──
PGADMIN_DEFAULT_EMAIL=admin@vallecafe24.com
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_PORT=5050

# ── Mailpit (dev) ──
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ── Almacenamiento de archivos (dev: local) ──
STORAGE_TYPE=local

# ── Login social (opcional en dev) ──
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
# Bundle/Service ID de la app (déjalos vacíos hasta migrar la identidad mobile a Valle Café)
APPLE_BUNDLE_ID=
APPLE_SERVICE_ID=

# ── Pagos — R4 Conecta (opcional en dev; vacío = método débito oculto) ──
R4_BASE_URL=https://r4conecta.mibanco.com.ve
R4_WEBHOOK_TOKEN=
R4_COMMERCE_ID=
R4_CUENTA_BANCO=
R4_CUENTA_CEDULA=
R4_CUENTA_TELEFONO=
R4_ALLOWED_IPS=
